{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MEDICAID",
  "version": "0.1.0",
  "identifier": "com.aheto.medicaid",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MEDICAID",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Business",
    "shortDescription": "MEDICAID desktop dashboard",
    "longDescription": "Desktop client for the MEDICAID registration, NHIS, analytics, and user management platform.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
