NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ewc_medicaid
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false
TRUST_PROXY=false
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:5173

# Optional bootstrap admin values for `node scripts/create_admin.mjs`
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin
ADMIN_FULL_NAME=Admin User
